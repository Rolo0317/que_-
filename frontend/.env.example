# ─── QUE+ Dashboard — Variables de entorno ────────────────────────────────────
# Copiar a .env.local en desarrollo y agregar en: Vercel → Project → Settings → Environment Variables

# ── Backend API (opcional — sin backend el Excel se procesa en el navegador) ──
VITE_API_URL=http://localhost:3000
# VITE_API_URL=https://tu-backend.railway.app  ← para producción

# ── Supabase — sincronización global de datos entre usuarios (opcional) ───────
# Sin estas variables los datos quedan solo en localStorage (por dispositivo).
# Con Supabase, cualquier usuario que cargue un Excel lo verá toda la organización.
#
# Cómo configurar:
#   1. Crear cuenta gratuita en https://supabase.com
#   2. Crear un nuevo proyecto
#   3. Ir a SQL Editor y ejecutar:
#
#      create table public.datasets (
#        id text primary key,
#        name text not null,
#        calls jsonb not null,
#        call_count integer not null,
#        loaded_at timestamptz not null default now(),
#        source text not null default 'excel'
#      );
#      alter table datasets enable row level security;
#      create policy "public read"   on datasets for select using (true);
#      create policy "public insert" on datasets for insert with check (true);
#      create policy "public delete" on datasets for delete using (true);
#
#   4. Ir a Project Settings → API y copiar:
#      - Project URL  → VITE_SUPABASE_URL
#      - anon public  → VITE_SUPABASE_ANON_KEY
#   5. Agregar ambas variables en Vercel → Environment Variables → Production
#
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── App metadata ──────────────────────────────────────────────────────────────
VITE_APP_NAME=QUE+ Dashboard
VITE_APP_VERSION=0.1.0
VITE_ENVIRONMENT=development

