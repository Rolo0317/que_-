# Configuración de Vercel para QUE+ Dashboard
# Copiar a .env.local en desarrollo y configurar en Vercel Dashboard

# API Backend URL - local development
VITE_API_URL=http://localhost:3000

# Para Vercel Production - reemplazar con tu dominio
# VITE_API_URL=https://api-backend.domain.com

# Información de la aplicación
VITE_APP_NAME=QUE+ Dashboard
VITE_APP_VERSION=0.1.0
VITE_ENVIRONMENT=development

# Para producción en Vercel, usar:
# VITE_ENVIRONMENT=production

